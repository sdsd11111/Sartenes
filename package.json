{
  "name": "los-sartenes",
  "version": "1.0.0",
  "description": "Sistema de gestión de menú para Los Sartenes",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build": "echo 'Build step started...' && mkdir -p public && cp -r components/ public/ && cp -r images/ public/ && cp -r admin/ public/ && cp -r css/ public/ && cp -r js/ public/ && cp -r menu/ public/ && cp *.html public/ && cp favicon.ico public/ 2>/dev/null || true",
    "vercel-build": "npm install && npm run build",
    "migrate": "mysql -u root -p < database/migrations/001_create_platos_del_dia.sql",
    "setup": "npm install && npm run migrate"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.58.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "mysql2": "^3.6.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "restaurant",
    "menu",
    "management",
    "nodejs",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "ISC"
}
