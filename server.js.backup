const express = require('express');
const path = require('path');
const fs = require('fs');
const cors = require('cors');
const { createClient } = require('@supabase/supabase-js');
const multer = require('multer');
require('dotenv').config();

const app = express();
const PORT = process.env.PORT || 9000;  // Puerto 9000 como predeterminado

// Configuración de Supabase
const supabaseUrl = process.env.SUPABASE_URL || 'https://hmljlcwfmxflxilhgmha.supabase.co';
const supabaseKey = process.env.SUPABASE_ANON_KEY || 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...';
const supabase = createClient(supabaseUrl, supabaseKey);

// Middleware
app.use(cors());
app.use(express.json());
app.use(express.urlencoded({ extended: true }));

// Configuración de archivos estáticos para la carpeta admin
app.use('/admin', express.static(path.join(__dirname, 'admin'), {
  index: false,
  extensions: ['html', 'js', 'css', 'png', 'jpg', 'jpeg', 'gif', 'ico', 'svg']
}));

// Configuración de archivos estáticos para la carpeta public
app.use(express.static(path.join(__dirname, 'public'), {
  index: false,
  extensions: ['html', 'js', 'css', 'png', 'jpg', 'jpeg', 'gif', 'ico', 'svg']
}));

// Ruta para el panel de administración
app.get('/admin', (req, res) => {
  res.sendFile(path.join(__dirname, 'admin', 'index.html'));
});

// Ruta para manejar la ruta raíz
app.get('/', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

// Ruta comodín para la SPA (debe ir al final)
app.get('*', (req, res) => {
