{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/admin", "dest": "/public/admin/index.html" },
    { "src": "/admin/(.*)", "dest": "/public/admin/$1" },
    { 
      "src": "/(.*\\.(css|js|json|xml))",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/public/$1"
    },
    { 
      "src": "/(.*\\.(jpg|jpeg|png|gif|ico|svg|webp|avif|woff|woff2|ttf|eot))",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/public/$1"
    },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
